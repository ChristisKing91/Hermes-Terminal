# Hermes Terminal Configuration
# Copy this file to .env and customize

# AI Provider Selection
# Options: ollama, openai
HERMES_AI_PROVIDER=ollama

# Ollama Configuration (used when HERMES_AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# OpenAI Configuration (used when HERMES_AI_PROVIDER=openai)
# OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-4

# Hermes Configuration Directory
HERMES_CONFIG_DIR=~/.config/hermes-terminal

# Database location (relative to HERMES_CONFIG_DIR)
HERMES_DATABASE=hermes.db

# Logging
HERMES_LOG_LEVEL=INFO
HERMES_LOG_DIR=~/.local/share/hermes-terminal/logs

# SSH Configuration
HERMES_SSH_KEY_PATH=~/.ssh/hermes_key
HERMES_SSH_TIMEOUT=30

# Security: Enable dangerous command confirmation
HERMES_REQUIRE_DANGEROUS_CONFIRMATION=true

# Audit logging
HERMES_AUDIT_ENABLED=true
