HERMES_AI_PROVIDER=ollama
HERMES_OLLAMA_BASE_URL=http://localhost:11434
HERMES_OLLAMA_MODEL=neural-chat:latest
HERMES_AI_TIMEOUT=300
HERMES_AUDIT_ENABLED=true
HERMES_AUDIT_REDACT_ENABLED=true
HERMES_ENABLE_LEARNING=true
HERMES_REQUIRE_DANGEROUS_CONFIRMATION=true
HERMES_DANGEROUS_CONFIRMATION_PREFIX=CONFIRM
HERMES_SSH_TIMEOUT=30
# Never commit passwords, API keys, or tokens here.
